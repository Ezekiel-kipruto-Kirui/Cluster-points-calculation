{
  "name": "kuccps-cluster-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "serve": "npm run build:backend-server && node ../backend-server/dist/index.js",
    "build:backend-server": "npm --prefix ../backend-server install && npm --prefix ../backend-server run build",
    "start": "npm run build && npm run serve"
  },
  "dependencies": {
    "lucide-react": "^0.574.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.9.3",
    "vite": "^5.4.12"
  }
}
