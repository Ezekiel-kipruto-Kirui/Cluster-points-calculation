{
  "name": "kuccps-cluster-backend-server",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "tsc -p tsconfig.json",
    "build:frontend:prod": "npm --prefix frontend run build",
    "build:backend:prod": "tsc -p tsconfig.json",
    "build:prod": "npm run build:frontend:prod && npm run build:backend:prod",
    "start": "node --env-file=.env dist/index.js",
    "start:local": "npm run start"
  },
  "dependencies": {
    "express": "^4.21.2",
    "nodemailer": "^7.0.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.23",
    "typescript": "^5.9.3"
  }
}
